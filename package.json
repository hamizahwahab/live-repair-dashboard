{
  "name": "live-repair-dashboard",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --port 3004",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3004 && electron .\"",
    "build": "next build",
    "electron:build": "next build && electron-builder",
    "start": "next start --port 3004",
    "lint": "eslint"
  },
  "build": {
    "appId": "com.aerosgeotech.live-repair-dashboard",
    "productName": "Live Repair Tracking Board",
    "files": [
      "out/**/*",
      "electron/**/*",
      "node_modules/sql.js/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": null
    }
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  }
}
